<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="6.0" 
    ExtensionBundleId="com.daryn.fasttools" 
    ExtensionBundleVersion="1.0.0" 
    ExtensionBundleName="FastTools">

    <ExtensionList>
        <Extension Id="com.daryn.fasttools.panel" Version="1.0.0"/>
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[0.0,99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="6.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.daryn.fasttools.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Fast Tools</Menu>
                    <Geometry>
                        <Size>
                            <Height>400</Height>
                            <Width>250</Width>
                        </Size>
                        <MinSize>
                            <Height>200</Height>
                            <Width>150</Width>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>